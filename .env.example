# Supabase
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Logo.dev — publishable key for provider logos in FieldInfo panel
# Get yours at https://logo.dev
VITE_LOGO_DEV_TOKEN=pk_your_publishable_key

# Notion integration — set as a Supabase secret (not in .env for local dev)
# Required by edge functions: prospect-submitted, handle-submission, design-locked, convert-prospect-to-client
# Get your integration token at: https://www.notion.so/my-integrations
# Set in production: supabase secrets set NOTION_TOKEN=secret_xxxxxxxxxxxxx
NOTION_TOKEN=secret_xxxxxxxxxxxxx
